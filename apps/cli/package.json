{
  "name": "@sisu/cli",
  "version": "0.1.0",
  "description": "Operational CLI for SISU — sisu binary with live dashboard",
  "type": "module",
  "bin": {
    "sisu": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "lint": "biome check ./src",
    "typecheck": "tsc --noEmit",
