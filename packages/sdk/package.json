{
  "name": "@sisu/sdk",
  "version": "0.1.0",
  "description": "TypeScript client for the SISU API",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "biome check ./src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@sisu/protocol": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
