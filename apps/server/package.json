{
  "name": "@sisu/server",
  "version": "0.1.0",
  "description": "Fastify HTTP API service for SISU",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "biome check ./src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage"
  },
  "dependencies": {
    "@sisu/core": "workspace:*",
    "@sisu/protocol": "workspace:*",
    "@sisu/templates-default": "workspace:*",
    "fastify": "^5.3.3",
    "fastify-plugin": "^5.0.1",
    "zod": "^3.24.2",
    "@sisu/runtime-openclaw": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.1.8",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
